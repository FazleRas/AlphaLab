# AlphaLab backend environment variables. Copy to backend/.env (gitignored).

# Supabase transaction pooler connection string (Project Settings -> Database ->
# Connection string -> "Transaction pooler"). Port 6543, host *.pooler.supabase.com.
# Do NOT use the direct db.<ref>.supabase.co:5432 string — it is IPv6-only and
# fails on Render.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase auth — how the backend verifies user access tokens on protected
# routes. Supabase signs tokens with either asymmetric or legacy-symmetric keys;
# the backend reads the token's `alg` header and supports both.
#
# Asymmetric (ES256/RS256 — the current Supabase default): set the project URL
# and the backend fetches the public keys from its JWKS endpoint. This is the
# one to use if Project Settings -> API -> JWT Keys shows signing keys with a
# JWKS URL rather than a copyable shared secret.
SUPABASE_URL=https://your-project-ref.supabase.co
# (Optional override if your JWKS lives elsewhere:)
# SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
#
# Legacy HS256 only: a shared secret from Project Settings -> API -> JWT Settings.
# Not needed when SUPABASE_URL is set for an asymmetric-key project.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
