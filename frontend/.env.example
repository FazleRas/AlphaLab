# AlphaLab frontend environment variables.
# Copy to .env.local and fill in — .env.local is gitignored.

# Point at a local backend instead of the deployed one (optional):
# REACT_APP_API_URL=http://localhost:8000

# Supabase project credentials (Project Settings -> API in the dashboard).
# The anon/public key is safe in the frontend; Row-Level Security protects data.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key
